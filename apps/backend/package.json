    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "prisma": "^6.16.0",
    "tsx": "^4.19.2"
  }
